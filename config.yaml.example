# ============================================================
# Server
# ============================================================
host: "0.0.0.0"
port: 8000

# ============================================================
# LLM — Chat & VLM OCR
# ============================================================
openai_api_key: "sk-your-openai-key-here"
openai_base_url: null                       # 代理地址，不用代理则设为 null

anthropic_api_key: "sk-ant-your-anthropic-key-here"
anthropic_base_url: null

# ============================================================
# Embedding
# ============================================================
embedding_model: "text-embedding-3-small"
embedding_api_key: ""                       # 不填则复用 openai_api_key
embedding_base_url: null                    # 不填则复用 openai_base_url

# ============================================================
# Storage — ChromaDB
# ============================================================
chroma_persist_dir: "./data/chroma"
chroma_collection_name: "career_assistant"

# ============================================================
# Processing
# ============================================================
chunk_size: 800
chunk_overlap: 120
pdf_dpi: 200

# ============================================================
# Dedup — 文档去重
# ============================================================
dedup_enabled: true                         # 入库后自动检测并删除重复旧文档
dedup_similarity_threshold: 0.85            # 相似度阈值（0-1，越高越严格）
